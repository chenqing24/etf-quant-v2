# v2 重构项目排除规则

# 数据（运行时生成，不入 git）
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.benchmarks/   # pytest-benchmark 输出
.coverage
htmlcov/

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# 系统
.DS_Store
Thumbs.db

# 临时文件
*.log
*.tmp
*.bak

# v1 引用（只读，不入 git）
# etf_strategy/ 是 v1 旧仓参考

# 备份
.archive/

# 测试产物（scripts/run_unit_tests.sh 生成）
reports/pytest/*.log

# 决策报告（运行时产物，按日期分目录，cron 写）
# 顶层 reports/2026-06-24_daily_run/ 是开发复盘留底，本地保留不入 git
reports/etf-daily/
reports/etf-daily-logs/
reports/etf-daily-logs-test/